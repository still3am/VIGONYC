# Base44 Environment Variables Configuration

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=my_user
DB_PASSWORD=my_password
DB_NAME=my_database

# App configuration
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:yourkeyhere

# Email configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
